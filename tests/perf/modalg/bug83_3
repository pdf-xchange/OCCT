#####################################################################
# BUC60912. Section of simple BSpline surfaces is performed too slow.
#####################################################################

restore [locate_data_file BUC60912_sec_slow.brep] c

explode c
renamevar c_1 sh
renamevar c_2 pr

plane f 0 0 0 1 0 0
mkface f f -11 11 -11 11

puts "Info: perform section with plane"
dchrono h1 -restart
repeat 10 {bsection r1 f pr}
dchrono h1 -stop -counter "CPU section r1"
set h1_Time [dchrono h1 -elapsed]

puts "Info: perform section with planar BSpline surface"
dchrono h2 -restart
repeat 10 {bsection r2 sh pr}
dchrono h2 -stop -counter "CPU section r2"
set h2_Time [dchrono h2 -elapsed]

set max_ratio 15.0
if { ${h2_Time} > [expr ${h1_Time} * $max_ratio] } {
   puts "Error: Section with planar BSpline surfaces is performed too slow"
}
