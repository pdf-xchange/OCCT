cpulimit 300

if { $::tcl_platform(os) == "Darwin" } {
  puts "TEST COMPLETED"
  return -code 1 "Skipping testgrid 'opengles3': not configured for macOS"
}

if { ![regexp HAVE_GLES2 [dversion]] } {
  error "OCCT is built without Open GL ES support"
}

pload VISUALIZATION
vdriver -load GLES
vgldebug -glslWarn 1
vcaps -useWinBuffer 0

if { [info exists imagedir] == 0 } { set imagedir . } 
