puts "================"
puts "OCC309: OSD_Path::UpTrek() returns wrong path for OSD_Process::CurrentDirectory()"
puts "================"
puts ""

pload QAcommands

set testPath "/where/you/want/tmp/qwerty/tmp/"
set sysname [QAOsdPathPart $testPath -sysname]
set parent  [QAOsdPathPart $testPath -parent]
if { "$sysname" != "/where/you/want/tmp/qwerty/tmp/"} { puts "Error: wrong Linux sysname '$sysname'"}
if { "$parent" != "/where/you/want/tmp/qwerty/"}      { puts "Error: wrong Linux parent '$parent'"}

if { [checkplatform -windows] } {
  set testPath2 "C:\\where\\you\\want\\tmp\\qwerty\\tmp\\"
  set sysname2 [QAOsdPathPart $testPath2 -sysname]
  set parent2  [QAOsdPathPart $testPath2 -parent]
  if { "$sysname2" != "C:/where/you/want/tmp/qwerty/tmp/"} { puts "Error: wrong Windows sysname '$sysname2'"}
  if { "$parent2"  != "C:/where/you/want/tmp/qwerty/"}     { puts "Error: wrong Windows parent '$parent2'"}
}
