puts "================"
puts "OCC310: OSD_Path::UpTrek() returns wrong path"
puts "================"
puts ""

pload QAcommands

set testPath "/where/you/want/tmp/qwerty/tmp/"
set trek   [QAOsdPathPart $testPath -trek]
set uptrek [QAOsdPathPart $testPath -uptrek]
if { "$trek"   != "|where|you|want|tmp|qwerty|tmp|"} { puts "Error: wrong Linux trek '$trek'"}
if { "$uptrek" != "|where|you|want|tmp|qwerty|"}     { puts "Error: wrong Linux uptrek '$uptrek'"}

if { [checkplatform -windows] } {
  set testPath2 "C:\\where\\you\\want\\tmp\\qwerty\\tmp\\"
  set trek2   [QAOsdPathPart $testPath2 -trek]
  set uptrek2 [QAOsdPathPart $testPath2 -uptrek]
  if { "$trek2"   != "|where|you|want|tmp|qwerty|tmp|"} { puts "Error: wrong Windows trek '$trek2'"}
  if { "$uptrek2" != "|where|you|want|tmp|qwerty|"}     { puts "Error: wrong Windows uptrek '$uptrek2'"}
}
