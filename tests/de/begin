pload OCAF
pload TOPTEST
pload XDE

cpulimit 1000

# Create a new document and set UndoLimit
NewDocument D BinXCAF
UndoLimit D 100

# Local length unit value
set lengthunit_start ""

# Open a transaction
NewCommand D

# Reads resource file, returns options from file as key-value dict
proc parse_resource_file {theFileName} {
    # like CSF_STEPDefaults
    set aResFolder [dgetenv "CSF_${theFileName}Defaults"]
    set aResFile "${aResFolder}/${theFileName}"

    # Creating empty dictionary
    set aDict [dict create];
    # Check for resource file
    if { [file exists "${aResFile}"] == 0 } {
       puts "Error: resource file \"${aResFile}\" isn't found"
       return $aDict
   }
   # Open a resource file
   set aFD [open "${aResFile}" "rb"]
   set aLineNo 0
   # Read line by line
   while {[gets $aFD aLine] !=-1 } {
       incr aLineNo
       # Clear the line from comment
       if {[regexp {(^[^!]+)} $aLine match aClearLine]} {
          # remove spaces
          set aClearLine [string trim $aClearLine]
          if {[string length $aClearLine] != 0} {
             if {[regexp {(\S+)\s*:\s*(\S*)} $aClearLine match aKey aValue]} {
                 dict set aDict $aKey $aValue
             } else {
                puts "Error: syntax error in resource file at line: ${aLineNo}"
             }
          }   
       }
   }
   close $aFD
   return $aDict
}

# Creates new resource file with options as key-value dict
proc create_resource_file {theFileName theOptions} {
   # remember the path to the old resource file
   set ::bak_resource_path [dgetenv "CSF_${theFileName}Defaults"]

   # create folder for temporary resource file
   set ::tmp_resource_path "${::imagedir}/${::casename}_tmp"
   if {![file exists "${::tmp_resource_path}"]} { file mkdir "${::tmp_resource_path}" }
   dsetenv "CSF_${theFileName}Defaults" "${::tmp_resource_path}"
   puts "New path to CSF_${theFileName}Defaults resource file is: \"${::tmp_resource_path}\""

   # Open a resource file
   set aFD [open "${::tmp_resource_path}/${theFileName}" "wb"]
   set aLineNo 0
   # Write line by line
   dict for {aKey aValue} $theOptions {
       puts $aFD "${aKey} : ${aValue}"
   }
   close $aFD
}

# Remove temporary resource file
proc delete_resource_file {theFileName} {
   # delete path to temporary resource file
   if {[file exists "${::tmp_resource_path}/${theFileName}"]} { file delete -force "${::tmp_resource_path}/${theFileName}" }
   if {[file exists "${::tmp_resource_path}"]} { file delete -force "${::tmp_resource_path}" }

   # restore path to old resource file
   dsetenv "CSF_${theFileName}Defaults" "${::bak_resource_path}"
   puts "Restored path to CSF_${theFileName}Defaults resource file: \"${::bak_resource_path}\""
}
